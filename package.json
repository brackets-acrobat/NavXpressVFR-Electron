{
  "name": "navxpressvfr-electron",
  "version": "1.8.1",
  "description": "Logiciel de navigation VFR et tracking temps réel pour Flight Simulator",
  "main": "main.js",
  "author": "NavXpressVFR",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:portable": "electron-builder --win portable"
  },
  "keywords": [
    "electron",
    "vfr",
    "msfs",
    "navigation",
    "simconnect"
  ],
  "dependencies": {
    "@electron/get": "^5.0.0",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.3.5",
    "geomagnetism": "^0.2.0",
    "node-simconnect": "^4.2.0",
    "wmm": "*"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.navxpressvfr.app",
    "productName": "NavXpressVFR",
    "copyright": "Copyright © 2026 NavXpressVFR",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!.git/**/*",
      "!dist/**/*",
      "!build/**/*",
      "!SimConnect.dll",
      "!fuel_selector.jpg",
      "!logo_icone.png",
      "!force-electron.js",
      "!package-lock.json",
      "!**/*.md"
    ],
    "extraResources": [],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-simconnect/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "logo_icone.png",
      "artifactName": "${productName}-${version}-portable.exe"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    }
  }
}
