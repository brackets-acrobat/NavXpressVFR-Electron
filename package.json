{
  "name": "navxpressvfr-electron",
  "version": "1.14.0",
  "description": "Logiciel de navigation VFR et tracking temps réel pour Flight Simulator",
  "main": "main.js",
  "author": "NavXpressVFR",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always",
    "probe:navaids": "node probe-navaids-msfs.js",
    "navaids:build": "node extract-navaids-msfs.js"
  },
  "keywords": [
    "electron",
    "vfr",
    "msfs",
    "navigation",
    "simconnect"
  ],
  "dependencies": {
    "@electron/get": "^5.0.0",
    "docx": "^9.7.1",
    "electron-updater": "^6.8.9",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.3.5",
    "geomagnetism": "^0.2.0",
    "node-simconnect": "^4.2.0",
    "wmm": "*"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.navxpressvfr.app",
    "productName": "NavXpressVFR",
    "copyright": "Copyright © 2026 NavXpressVFR",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!.git/**/*",
      "!dist/**/*",
      "!build/**/*",
      "!SimConnect.dll",
      "!fuel_selector.jpg",
      "!logo_icone.png",
      "!force-electron.js",
      "!package-lock.json",
      "!**/*.md",
      "!probe-navaids-msfs.js",
      "!analysis-navaid-fields.js",
      "!verify-range.js",
      "!_navtest/**/*",
      "!_navtest_full/**/*"
    ],
    "extraResources": [],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-simconnect/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo_icone.png",
      "artifactName": "${productName}-${version}-Setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NavXpressVFR",
      "artifactName": "${productName}-${version}-Setup.exe",
      "uninstallDisplayName": "NavXpressVFR ${version}"
    },
    "publish": {
      "provider": "github",
      "owner": "brackets-acrobat",
      "repo": "NavXpressVFR-Electron"
    }
  }
}
